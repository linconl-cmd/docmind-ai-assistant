# Copy this file to .env and fill in your Supabase project values.
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api

# Public anon key (safe to expose in browser bundles)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>

# Server-side only (used by SSR / Cloudflare Worker)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<anon-key>

# SERVICE ROLE KEY — never expose to the browser
# Required only for admin server functions
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional: used by Supabase CLI locally
VITE_SUPABASE_PROJECT_ID=<project-id>
